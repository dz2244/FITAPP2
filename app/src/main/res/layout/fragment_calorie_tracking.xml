<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F8FA"
    android:padding="24dp"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:layoutDirection="rtl">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/title_calorie_tracking"
            android:textColor="#111827"
            android:textSize="32sp"
            android:textStyle="bold" />

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/subtitle_calorie_tracking"
            android:textColor="#6B7280"
            android:textSize="16sp" />

        <!-- AI Scan Button (Changed to Black) -->
        <Button
            android:id="@+id/scanFoodBtn"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="24dp"
            android:backgroundTint="@android:color/black"
            android:text="Scan Food with AI"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textAllCaps="false" />

        <!-- Food Name Label -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:text="@string/label_food_name"
            android:textColor="#111827"
            android:textSize="16sp" />

        <!-- Food Name Display -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="55dp"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:background="@android:color/white">

            <TextView
                android:id="@+id/foodNameDisplay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#111827"
                android:textSize="16sp"
                android:textDirection="ltr"
                android:padding="8dp" />

        </LinearLayout>

        <!-- Calories Label -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:text="@string/label_calories"
            android:textColor="#111827"
            android:textSize="16sp" />

        <!-- Calories Display -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:background="@android:color/white">

            <TextView
                android:id="@+id/caloriesDisplay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#111827"
                android:textSize="16sp"
                android:textDirection="ltr"
                android:padding="8dp" />

        </LinearLayout>

        <!-- Protein Label -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:text="@string/label_protein"
            android:textColor="#111827"
            android:textSize="16sp" />

        <!-- Protein Display -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:background="@android:color/white">

            <TextView
                android:id="@+id/proteinDisplay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#111827"
                android:textSize="16sp"
                android:textDirection="ltr"
                android:padding="8dp" />

        </LinearLayout>

        <!-- Carbs Label -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:text="@string/label_carbs"
            android:textColor="#111827"
            android:textSize="16sp" />

        <!-- Carbs Display -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:background="@android:color/white">

            <TextView
                android:id="@+id/carbsDisplay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#111827"
                android:textSize="16sp"
                android:textDirection="ltr"
                android:padding="8dp" />

        </LinearLayout>

        <!-- Fats Label -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:text="@string/label_fats"
            android:textColor="#111827"
            android:textSize="16sp" />

        <!-- Fats Display -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:background="@android:color/white">

            <TextView
                android:id="@+id/fatsDisplay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#111827"
                android:textSize="16sp"
                android:textDirection="ltr"
                android:padding="8dp" />

        </LinearLayout>

        <!-- Add Meal Button -->
        <Button
            android:id="@+id/addMealBtn"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="12dp"
            android:backgroundTint="@android:color/black"
            android:text="@string/btn_add_meal"
            android:textColor="#FFFFFF"
            android:textSize="18sp" />

    </LinearLayout>

</ScrollView>
